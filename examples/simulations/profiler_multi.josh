start simulation ProfilerMultiExample

  grid.size = 1 count
  grid.low = 0 count latitude, 0 count longitude
  grid.high = 3 count latitude, 3 count longitude

  steps.low = 0 count
  steps.high = 5 count

  exportFiles.patch = "file:///tmp/profiler_multi_josh.csv"

end simulation


start patch Default

  TimedTree.init = create 50 count of TimedTree

  export.averageHeight.step = mean(TimedTree.height)
  export.avgHeightEvalDuration.step = mean(TimedTree.height.evalDuration)

end patch


start organism TimedTree

  height.init = 1 m
  height.step = prior.height + 1 m

  heightEvalDuration.step = height.evalDuration

end organism
