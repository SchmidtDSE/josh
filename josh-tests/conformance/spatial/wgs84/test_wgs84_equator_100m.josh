# @category: spatial
# @subcategory: wgs84
# @priority: critical
# @description: WGS84 within query at equator with 100m cells — verifies meter radius conversion

# 11x11 grid at equator (0°N, 30°E), 100m cells.
# Haversine: 0.009° lat ≈ 1001m, 0.009° lon at 0°N ≈ 1001m.
# within 150m = 1.5 cell radii → 13 neighbors for interior patches.
# If meter cell size were lost (old bug), radiusInGridCells = 300/(2*1) = 150 → all patches.

start simulation TestWgs84Equator100m

  grid.size = 100 m
  grid.low = 0.0 degrees latitude, 30.0 degrees longitude
  grid.high = 0.009 degrees latitude, 30.009 degrees longitude

  steps.low = 0 count
  steps.high = 2 count

end simulation

start patch Default

  Probe.init = create 1 count of Probe
  patchNeighborCount.step = mean(Probe.neighbors)

  # Interior patches (>= 2 cells from edge) must find exactly 13
  # Count-space centers: 0.5..10.5; interior: 2.5..8.5
  assert.interiorCount.step:if(meta.stepCount == 2 count and here.x > 2 m and here.x < 9 m and here.y > 2 m and here.y < 9 m) = current.patchNeighborCount == 13 count

  # No patch should find more than 13 (would indicate broken radius)
  assert.noOvercount.step:if(meta.stepCount == 2 count) = current.patchNeighborCount <= 13 count

  # Every patch finds at least itself
  assert.atLeastSelf.step:if(meta.stepCount == 2 count) = current.patchNeighborCount >= 1 count

end patch

start organism Probe
  age.init = 0 year
  age.step = prior.age + 1 year
  neighbors.step = count(Default within 150 m radial at prior)
end organism

start unit year
  alias years
end unit

start unit m
  alias meter
  alias meters
end unit

start unit degree
  alias degrees
end unit

start unit count
end unit
