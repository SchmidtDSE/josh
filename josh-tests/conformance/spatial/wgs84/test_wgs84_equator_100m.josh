# @category: spatial
# @subcategory: wgs84
# @priority: critical
# @description: WGS84 within query at equator with 100m cells — multi-radius with edge/corner checks

# 11x11 grid at equator (0°N, 30°E), 100m cells.
# Three radii: 50m (0.5 cells), 150m (1.5 cells), 250m (2.5 cells).
# Expected interior counts: 5, 13, 29.
# Edge patches find fewer; corners find fewest.
# If meter cell size were lost (old bug): radiusInGridCells = 300/(2*1) = 150 → all patches.

start simulation TestWgs84Equator100m

  grid.size = 100 m
  grid.low = 0.0 degrees latitude, 30.0 degrees longitude
  grid.high = 0.009 degrees latitude, 30.009 degrees longitude

  steps.low = 0 count
  steps.high = 2 count

end simulation

start patch Default

  Probe.init = create 1 count of Probe

  small.step = mean(Probe.nSmall)
  medium.step = mean(Probe.nMedium)
  large.step = mean(Probe.nLarge)

  # Interior exact counts (>= 2 cells from edge for small/medium, >= 3 for large)
  assert.interiorSmall.step:if(meta.stepCount == 2 count and here.x > 2 m and here.x < 9 m and here.y > 2 m and here.y < 9 m) = current.small == 5 count
  assert.interiorMedium.step:if(meta.stepCount == 2 count and here.x > 2 m and here.x < 9 m and here.y > 2 m and here.y < 9 m) = current.medium == 13 count
  assert.interiorLarge.step:if(meta.stepCount == 2 count and here.x > 3 m and here.x < 8 m and here.y > 3 m and here.y < 8 m) = current.large == 29 count

  # Monotonicity: larger radius finds at least as many everywhere
  assert.mono1.step:if(meta.stepCount == 2 count) = current.small <= current.medium
  assert.mono2.step:if(meta.stepCount == 2 count) = current.medium <= current.large

  # No overcount anywhere
  assert.noOverSmall.step:if(meta.stepCount == 2 count) = current.small <= 5 count
  assert.noOverMedium.step:if(meta.stepCount == 2 count) = current.medium <= 13 count
  assert.noOverLarge.step:if(meta.stepCount == 2 count) = current.large <= 29 count

  # Edge patches (within 2 cells of boundary) find strictly fewer at medium radius
  assert.edgeFewer.step:if(meta.stepCount == 2 count and (here.x < 2 m or here.x > 9 m or here.y < 2 m or here.y > 9 m)) = current.medium < 13 count

  # Corner patches find strictly fewer than edge patches at medium radius
  assert.cornerFewest.step:if(meta.stepCount == 2 count and here.x < 1 m and here.y < 1 m) = current.medium == 6 count

  # Mid-edge patches (not near corners) at medium radius
  assert.edgeCount.step:if(meta.stepCount == 2 count and here.x < 1 m and here.y > 2 m and here.y < 9 m) = current.medium == 9 count

  # Every patch finds at least itself
  assert.atLeastSelf.step:if(meta.stepCount == 2 count) = current.small >= 1 count

end patch

start organism Probe
  age.init = 0 year
  age.step = prior.age + 1 year
  nSmall.step = count(Default within 50 m radial at prior)
  nMedium.step = count(Default within 150 m radial at prior)
  nLarge.step = count(Default within 250 m radial at prior)
end organism

start unit year
  alias years
end unit

start unit m
  alias meter
  alias meters
end unit

start unit degree
  alias degrees
end unit

start unit count
end unit
