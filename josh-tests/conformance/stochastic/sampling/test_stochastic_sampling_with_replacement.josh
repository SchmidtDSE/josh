# @category: stochastic
# @subcategory: sampling
# @priority: medium
# @description: Test sampling behavior with replacement - verifies that repeated sampling can produce duplicates

start simulation StochasticSamplingWithReplacement

  grid.size = 1 km
  grid.low.x = 0 m
  grid.low.y = 0 m
  grid.high.x = 1 km
  grid.high.y = 1 km  # 1x1 grid
  grid.patch = "Default"

  steps.low = 0 count
  steps.high = 1 count

end simulation

start patch Default

  # Create organisms that sample from a small discrete set
  # Sample 200 times from a small range [1, 10] - expect duplicates
  TestOrg.init = create 200 count of TestOrg

  # Count occurrences of each value to verify duplicates exist
  # If sampling with replacement, we should see repeated values
  count1.step = count(TestOrg[TestOrg.discreteValue >= 0.5 count and TestOrg.discreteValue < 1.5 count])
  count2.step = count(TestOrg[TestOrg.discreteValue >= 1.5 count and TestOrg.discreteValue < 2.5 count])
  count3.step = count(TestOrg[TestOrg.discreteValue >= 2.5 count and TestOrg.discreteValue < 3.5 count])
  count4.step = count(TestOrg[TestOrg.discreteValue >= 3.5 count and TestOrg.discreteValue < 4.5 count])
  count5.step = count(TestOrg[TestOrg.discreteValue >= 4.5 count and TestOrg.discreteValue < 5.5 count])
  count6.step = count(TestOrg[TestOrg.discreteValue >= 5.5 count and TestOrg.discreteValue < 6.5 count])
  count7.step = count(TestOrg[TestOrg.discreteValue >= 6.5 count and TestOrg.discreteValue < 7.5 count])
  count8.step = count(TestOrg[TestOrg.discreteValue >= 7.5 count and TestOrg.discreteValue < 8.5 count])
  count9.step = count(TestOrg[TestOrg.discreteValue >= 8.5 count and TestOrg.discreteValue < 9.5 count])
  count10.step = count(TestOrg[TestOrg.discreteValue >= 9.5 count and TestOrg.discreteValue < 10.5 count])

  # Test 1: All values should be in [1, 10] (approximately - sampling uniform from 0.5 to 10.5)
  minValue.step = min(TestOrg.discreteValue)
  maxValue.step = max(TestOrg.discreteValue)
  assert.inRange.step = (minValue >= 0.5 count) and (maxValue <= 10.5 count)

  # Test 2: Total counts should sum to sample size (200)
  totalCount.step = count1 + count2 + count3 + count4 + count5 + count6 + count7 + count8 + count9 + count10
  assert.totalCount.step = totalCount == 200 count

  # Test 3: With replacement, expect multiple occurrences of most values
  # With 200 samples from 10 buckets, expected count per bucket is 20
  # We verify duplicates exist by checking that max count is well above minimum
  # (if there were no duplicates/replacement, counts would be more uniform)
  maxCount.step = max(count1 | count2 | count3 | count4 | count5 | count6 | count7 | count8 | count9 | count10)
  minCount.step = min(count1 | count2 | count3 | count4 | count5 | count6 | count7 | count8 | count9 | count10)

  # Test 3a: Maximum count should be well above minimum (random variance from replacement)
  # This verifies the sampling produces uneven distribution as expected
  assert.hasVariance.step = (maxCount - minCount) > 0 count

  # Test 3b: At least one bucket should have more than 15 occurrences
  # (with expected value of 20 per bucket, this is very likely)
  assert.hasDuplicates.step = maxCount > 15 count

  # Test 3c: Verify mean count is approximately 20 (200 samples / 10 buckets)
  meanCount.step = totalCount / 10 count
  assert.meanCount.step = (meanCount >= 19 count) and (meanCount <= 21 count)

end patch

start organism TestOrg

  # Sample uniformly from [0.5, 10.5] then round to get discrete values [1, 10]
  continuousValue.init = sample uniform from 0.5 count to 10.5 count
  discreteValue.init = continuousValue
  discreteValue.step = prior.discreteValue

end organism

start unit degrees
end unit

start unit count
end unit

start unit m
  alias meter
  alias meters
  km = current / 1000
end unit

start unit km
  alias kilometer
  alias kilometers
  m = current * 1000
end unit
